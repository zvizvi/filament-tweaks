        "@tailwindcss/typography": "^0.5.20",
        "autoprefixer": "^10.5.4",
        "esbuild": "^0.28.1",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.19",
        "postcss-import": "^15.1.0",
        "prettier": "^3.9.5",
        "prettier-plugin-tailwindcss": "^0.8.1",
        "tailwindcss": "^3.4.19"
    }
}
